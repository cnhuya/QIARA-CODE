const RAW_VK: vector<u8> = x"";

const RAW_INPUTS: vector<u8> = x"";

const RAW_PROOF: vector<u8> = x"beeb8b4345b66f55a9b8b589382d9808ef6bed10c863ef2db838ff84a897532a133f5c2ce97c5ac3bcced98185cb1d619dff01c0d63184c48f73777817910119c70e46f3cfea40d367396369c05d1947f22711bf04a33a0cfc2f0ef43b8f528d9312289b3eb7d5f745bfd5181223b15deda15601e6d7405206daa5abffd3f9a3";
  
  
    public struct AllowanceKey has copy, drop, store { 
        user: address, 
        token_type: TypeName 
    }

// --- Initialization ---

    fun init(ctx: &mut TxContext) {
        verify_balanceM();
    }

    public fun verify_balanceM() { 
        let curve = groth16::bn254();
        
        let pvk = groth16::prepare_verifying_key(&curve, &RAW_VK);
        
        let pi_struct = groth16::public_proof_inputs_from_bytes(RAW_INPUTS);
        let pp_struct = groth16::proof_points_from_bytes(RAW_PROOF);

        // Verification call
        assert!(groth16::verify_groth16_proof(&curve, &pvk, &pi_struct, &pp_struct), 2222);
        
    }

    public fun verify_balance(public_inputs: vector<u8>, proof_points: vector<u8>) { 
        let curve = groth16::bn254();
        
        let pvk = groth16::prepare_verifying_key(&curve, &RAW_VK);
        
        let pi_struct = groth16::public_proof_inputs_from_bytes(public_inputs);
        let pp_struct = groth16::proof_points_from_bytes(proof_points);

        // Verification call
        assert!(groth16::verify_groth16_proof(&curve, &pvk, &pi_struct, &pp_struct), 2222);
        
    }

}
